# Copy to .env and fill in. All values are public client identifiers
# (no secrets) since this is a browser-only PKCE app.

# Azure AD application (client) ID — from the Azure Portal app registration
VITE_MS_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure AD tenant. Use "common" for multi-tenant, or your tenant ID.
VITE_MS_AUTHORITY=https://login.microsoftonline.com/common

# Slack app client ID — from https://api.slack.com/apps
VITE_SLACK_CLIENT_ID=0000000000.0000000000000

# Default Cloudflare Worker URL used to proxy Slack API calls.
# Can also be overridden per-user in the Settings page.
VITE_SLACK_PROXY_URL=https://watermelon-slack-proxy.example.workers.dev
